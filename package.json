{
  "name": "expedition-hq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run web:build",
    "web:dev": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "seed:validate": "node scripts/run-python.mjs scripts/validate_seed.py",
    "api:init": "node scripts/run-python.mjs scripts/init_db.py",
    "api:dev": "cd apps/api && node ../../scripts/run-python.mjs -m uvicorn expedition_hq_api.main:app --reload --host 127.0.0.1 --port 8789",
    "api:test": "node scripts/run-python.mjs -m pytest apps/api/tests --basetemp runtime/pytest-temp-api -p no:cacheprovider",
    "api:test:local": "node scripts/run-python.mjs -m pytest apps/api/tests --basetemp runtime/pytest-temp-local -p no:cacheprovider",
    "memory:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Initialize-CodexMemory.ps1",
    "memory:stats": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Get-MemoryStats.ps1",
    "memory:review": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Review-Memory.ps1",
    "memory:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Test-MemoryRedaction.ps1"
  }
}
