{
  "name": "expedition-hq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npm run web:build",
    "web:dev": "cd apps/web && npm run dev",
    "web:build": "cd apps/web && npm run build",
    "seed:validate": "python scripts/validate_seed.py",
    "api:init": "python scripts/init_db.py",
    "api:dev": "cd apps/api && python -m uvicorn expedition_hq_api.main:app --reload --host 127.0.0.1 --port 8789",
    "api:test": "python -m pytest apps/api/tests"
  }
}
